{
  "name": "wetocode",
  "version": "0.2.7",
  "private": true,
  "description": "更符合中国开发者使用习惯的中文桌面 Coding Agent",
  "main": "electron/main.cjs",
  "bin": {
    "wetocode": "bin/wetocode.mjs"
  },
  "author": "WetoCode Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitospdb/WetoCode.git"
  },
  "homepage": "https://github.com/vitospdb/WetoCode#readme",
  "bugs": {
    "url": "https://github.com/vitospdb/WetoCode/issues"
  },
  "type": "module",
  "scripts": {
    "cli": "node ./bin/wetocode.mjs",
    "pack:cli": "node scripts/pack-cli.mjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:server": "node scripts/smoke-opencode-server.mjs",
    "smoke:electron-permission": "node scripts/smoke-electron-permission.mjs",
    "smoke:pty": "node scripts/smoke-opencode-pty.mjs",
    "smoke:electron-terminal": "node scripts/smoke-electron-terminal.mjs",
    "smoke:worktree": "node scripts/smoke-opencode-worktree.mjs",
    "smoke:electron-worktree": "node scripts/smoke-electron-worktree.mjs",
    "smoke:electron-attachment": "node scripts/smoke-electron-attachment.mjs",
    "smoke:electron-background": "node scripts/smoke-electron-background.mjs",
    "smoke:electron-goal": "node scripts/smoke-electron-goal.mjs",
    "smoke:electron-parallel": "node scripts/smoke-electron-parallel.mjs",
    "smoke:electron-automation": "node scripts/smoke-electron-automation.mjs",
    "smoke:electron-preview": "node scripts/smoke-electron-preview.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && node scripts/prepare-opencode.mjs win32 x64 && node scripts/build-win.mjs",
    "dist:win:dir": "npm run build && node scripts/prepare-opencode.mjs win32 x64 && electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.17.18",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@fontsource-variable/noto-sans-sc": "^5.2.8",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "lucide-react": "^0.468.0",
    "opencode-ai": "1.17.18",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "cn.wetocode.desktop",
    "productName": "WetoCode",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/opencode-ai/**/*",
      "!node_modules/opencode-windows-*/**/*",
      "!node_modules/opencode-linux-*/**/*",
      "!node_modules/opencode-darwin-*/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "extraResources": [
        {
          "from": "node_modules/opencode-ai/bin/opencode.exe",
          "to": "bin/opencode.exe"
        }
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "signExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "extraResources": [
        {
          "from": ".build/opencode/win32-x64/opencode.exe",
          "to": "bin/opencode.exe"
        }
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WetoCode",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "publish": {
      "provider": "github",
      "owner": "vitospdb",
      "repo": "WetoCode"
    }
  }
}
